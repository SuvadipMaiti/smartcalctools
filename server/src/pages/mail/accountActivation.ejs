<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= companyname %> : Account Activation</title>
    <style>
        /* CSS styles for the card */
        .card {
            border: 2px solid #ccc;
            border-radius: 10px;
            overflow: hidden;
            /* Ensure content doesn't overflow border */
            display: flex;
            /* Enable flexbox layout */
            margin-bottom: 20px;
        }

        /* CSS styles for the logo */
        .logo-container {
            flex: 30%;
            /* Logo takes up 30% of width */
        }

        .logo {
            max-width: 100%;
            /* Adjust as needed */
            height: auto;
        }

        /* CSS styles for the content */
        .content-container {
            flex: 70%;
            /* Content takes up 70% of width */
            padding: 20px;
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="logo-container">
            <!-- Logo on the left side -->
            <img class="logo" src="<%= companylogo %>" alt="Logo">
        </div>
        <!-- Information on the right side -->
        <div class="content-container">
            <h1><%= companyname %> : Account Activation</h1>
            <h2>Hello <%= name %>,</h2>
            <p>Welcome to our platform! To activate your account, please click on the following link:</p>
            <p><a href="<%= activationLink %>">Activate Your Account</a></p>
            <p>If you didn't request this, please ignore this email.</p>
            <p>Regards,<br>
                <%= companyname %>
            </p>
        </div>
    </div>
</body>

</html>