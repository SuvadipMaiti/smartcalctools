```gitignore
# =========================
# Root
# =========================
.DS_Store
Thumbs.db
*.log

# =========================
# React Client
# =========================
client/node_modules
client/build
client/dist
client/.env
client/.env.local
client/.env.production
client/.env.development
client/server/node_modules



# Vite Cache
client/.vite

# =========================
# Express Server
# =========================
server/node_modules
server/.env
server/.env.local
server/.env.production
server/.env.development

# Logs
server/logs
server/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# IDE Files
# =========================
.vscode/
.idea/

# =========================
# Testing & Coverage
# =========================
coverage/
.nyc_output/

# =========================
# Cache
# =========================
.cache/
.eslintcache

# =========================
# Temporary Files
# =========================
*.tmp
*.temp

# =========================
# Optional Upload Folder
# Uncomment if uploads should not be tracked
# =========================
# server/uploads/
```
